DEFINE_UI_PARAMS(p_Exp, 🎥 Exposure, DCTLUI_SLIDER_FLOAT, 0, -5, 5, 0.001)

DEFINE_UI_PARAMS(p_SubSat, Sub. Saturation, DCTLUI_SLIDER_FLOAT, 0.0, -1.0, 1.0, 0.001)

DEFINE_UI_PARAMS(p_Ramp, 💩 Ramp, DCTLUI_CHECK_BOX, 0)

// Transfer Functions
__DEVICE__ float3 fromDWG (float3 in) {
    float3 out;

    float a = 0.0075f;
    float b = 7.0f;
    float c = 0.07329248f;
    float m = 10.44426855f;
    float log_cut = 0.02740668f;

    out.x = in.x > log_cut ? _powf(2.0f, (in.x / c) - b) - a : in.x / m;
    out.y = in.y > log_cut ? _powf(2.0f, (in.y / c) - b) - a : in.y / m;
    out.z = in.z > log_cut ? _powf(2.0f, (in.z / c) - b) - a : in.z / m;
    
    return out;
}

__DEVICE__ float3 toDWG (float3 in) {
    float3 out;

    float a = 0.0075;
    float b = 7.0;
    float c = 0.07329248;
    float m = 10.44426855;
    float lin_cut = 0.00262409;

    out.x = in.x > lin_cut ? (_log2f(in.x + a) + b) * c : out.x = in.x * m;
    out.y = in.y > lin_cut ? (_log2f(in.y + a) + b) * c : out.y = in.y * m;
    out.z = in.z > lin_cut ? (_log2f(in.z + a) + b) * c : out.z = in.z * m;

    return out;
}

// Subtractive Saturation via Tetra (Hexadecant) Model
// Each hexadecant identifies the minimum channel (achromatic component),
// then scales the chromatic content by (1 - sat) toward that neutral.
__DEVICE__ float3 applyTetraSubSat(float p_R, float p_G, float p_B, float sat) {
    float3 Color;
    float sf = 1.0f - sat;

    if (p_R > p_G) {
        if (p_G > p_B) {
            // Red-Yellow: min = B
            Color = make_float3(p_B + sf * (p_R - p_B), p_B + sf * (p_G - p_B), p_B);
        } else if (p_R > p_B) {
            // Red-Magenta: min = G
            Color = make_float3(p_G + sf * (p_R - p_G), p_G, p_G + sf * (p_B - p_G));
        } else {
            // Blue-Magenta: min = G
            Color = make_float3(p_G + sf * (p_R - p_G), p_G, p_G + sf * (p_B - p_G));
        }
    } else {
        if (p_B > p_G) {
            // Blue-Cyan: min = R
            Color = make_float3(p_R, p_R + sf * (p_G - p_R), p_R + sf * (p_B - p_R));
        } else if (p_B > p_R) {
            // Green-Cyan: min = R
            Color = make_float3(p_R, p_R + sf * (p_G - p_R), p_R + sf * (p_B - p_R));
        } else {
            // Green-Yellow: min = B
            Color = make_float3(p_B + sf * (p_R - p_B), p_B + sf * (p_G - p_B), p_B);
        }
    }

    return Color;
}

__DEVICE__ float3 transform(int p_Width, int p_Height, int p_X, int p_Y, float p_R, float p_G, float p_B) {
    float3 in_RGB = make_float3(p_R, p_G, p_B);
    float3 out = in_RGB;

    if (p_Ramp == 1) {
        float width = (float) p_Width;
        float height = (float) p_Height;
        float X = (float) p_X;
        float Y = (float) p_Y;
        float rX = X/width;
        float rY = Y/height;

        if (rY > 0.95f) {
            out = make_float3(rX, rX, rX);
        }
    }

    // Convert DaVinci Intermediate to Linear
    out = fromDWG (out);

    // Exposure
    out *= _powf(2, p_Exp);

    // Convert Linear to DaVinci Intermediate
    out = toDWG (out);

    // Subtractive Saturation (Tetra Model)
    out = applyTetraSubSat(out.x, out.y, out.z, p_SubSat);

    return out;
}